<jasperReport name="batches" language="java" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="ebfc0953-bcee-4248-bb11-75a35d68d239">
