    <parameter name="LOGO" class="java.io.InputStream"/>
    <parameter name="LOGO_TEXT" class="java.io.InputStream"/>
    <parameter name="ORDER_BY" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT
	b.manufacturing,
	b.validity,
	COALESCE(b.quantity,0) AS quantity,
	b.batch_number,
	b.location,
	received_at,
	p.name,
	p.code,
	COALESCE(p.price,0) AS price,
	(COALESCE(b.quantity, 0) * COALESCE(p.price, 0.00)) AS total_value
FROM stock_control_db.tb_batch b
	INNER JOIN stock_control_db.tb_product p ON 
	 b.product_id = p.id
    ORDER BY $P!{ORDER_BY}]]></query>
