	<query language="SQL"><![CDATA[SELECT p.id,
	p.name,
	p.code,
	p.price,
	COALESCE(pt.name, 'Sem Tipo') AS product_type 
FROM stock_control_db.tb_product p
	LEFT JOIN stock_control_db.tb_product_type pt ON 
	 p.product_type_id = pt.id
     ORDER BY p.name ASC]]></query>
